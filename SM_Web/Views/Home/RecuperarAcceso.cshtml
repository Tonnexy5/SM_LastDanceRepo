@{
    Layout = "_LayoutExterno";
}

<div class="row h-100">
    <div class="col-lg-6 col-12">
        <div id="auth-left">
            <div class="auth-logo">
                <a asp-action="Index" asp-controller="Home"><img src="~/images/logo.png" alt="Logo"></a>
            </div>
            <h1 class="auth-title">Recuperar Acceso</h1>
            <p class="auth-subtitle mb-5">Aqui recupares tu cuenta pana(Funcionamos igual que Steam bro tu tranquilo Bv ).</p>

            <form action="index.html">
                <div class="form-group position-relative has-icon-left mb-4">
                    <input type="email" class="form-control form-control-xl" placeholder="Correo Electronico">
                    <div class="form-control-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>
                <button class="btn btn-primary btn-block btn-lg shadow-lg mt-5">Send</button>
            </form>
            <div class="text-center mt-5 text-lg fs-4">
                <p class='text-gray-600'>
                    Recuerdas tu contraseña? <a asp-action="Index" asp-controller="Home" class="font-bold">
                    Iniciar Sesion
                </a>.
            </p>
        </div>
    </div>
</div>
<div class="col-lg-6 d-none d-lg-block">
    <div id="auth-right">
    </div>
</div>
</div>