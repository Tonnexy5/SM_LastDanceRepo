
@model UsuarioModel

@{
    Layout = "_LayoutExterno";
}



<div class="row h-100">
    <div class="col-lg-6 col-12">
        <div id="auth-left">
            <div class="auth-logo">
                <a asp-action="Index" asp-controller="Home"><img src="~/images/logo.png" alt="Logo"></a>
            </div>
            <h1 class="auth-title">Iniciar Sesion</h1>
            <p class="auth-subtitle mb-5">Aqui inicias sesion bro</p>

            <form asp-action="Index" asp-controller="Home" method="post">
                <div class="form-group position-relative has-icon-left mb-4">
                    <input asp-for="correoElectronico" type="text" class="form-control form-control-xl" placeholder="Correo Electronico">
                    <div class="form-control-icon">
                        <i class="bi bi-envelope"></i>
                    </div>
                </div>
                <div class="form-group position-relative has-icon-left mb-4">
                    <input asp-for="Contrasenna" type="password" class="form-control form-control-xl" placeholder="Contraseña">
                    <div class="form-control-icon">
                        <i class="bi bi-shield-lock"></i>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary btn-block btn-lg shadow-lg mt-2">Procesar</button>
            </form>
            <div class="text-center mt-5 text-lg fs-4">
                <p class="text-gray-600">
                    No tienes cuenta? <a asp-action="Registro" asp-controller="Home"
                                          class="font-bold">
                    Registrar Usuario
                </a>.
            </p>
            <p><a class="font-bold" asp-action="RecuperarAcceso" asp-controller="Home">Olvido su contraseña?</a>.</p>
        </div>
    </div>
</div>
<div class="col-lg-6 d-none d-lg-block">
    <div id="auth-right">
    </div>
</div>
</div>